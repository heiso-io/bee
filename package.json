{
  "name": "@heiso-io/bee",
  "version": "0.0.1-alpha.4",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/heiso-io/bee.git"
  },
  "exports": {
    "./lib/*": "./lib/*.ts",
    "./lib/db/schema/auth/*": "./lib/db/schema/auth/*.ts",
    "./lib/db/schema/permissions/*": "./lib/db/schema/permissions/*.ts",
    "./lib/db/schema/system/*": "./lib/db/schema/system/*.ts",
    "./lib/db/schema/features/*": "./lib/db/schema/features/*.ts",
    "./lib/db/schema/features/api-key": "./lib/db/schema/features/api-key/index.ts",
    "./lib/db/schema/features/api-key/*": "./lib/db/schema/features/api-key/*.ts",
    "./lib/db/schema/features/file": "./lib/db/schema/features/file/index.ts",
    "./lib/db/schema/features/file/*": "./lib/db/schema/features/file/*.ts",
    "./components/*": "./components/*.tsx",
    "./types/*": "./types/*.ts",
    "./modules/*": [
      "./modules/*.ts",
      "./modules/*.tsx"
    ],
    "./i18n/*": "./i18n/*.ts",
    "./emails/*": "./emails/*.tsx",
    "./providers/*": "./providers/*.tsx",
    "./globals.css": {
      "style": "./globals.css",
      "default": "./globals.css"
    },
    "./config": "./config/index.ts",
    "./config/*": "./config/*.ts",
    "./hooks/*": "./hooks/*.ts",
    "./server/*": "./server/*.ts"
  },
  "scripts": {
    "dev": "bun run:permission && bun x next dev --turbo",
    "build": "bun x next build",
    "start": "bun x next start",
    "db:generate": "bun x drizzle-kit generate",
    "db:push": "bun x drizzle-kit push",
    "db:studio": "bun x drizzle-kit studio",
    "db:migrate": "bun x drizzle-kit migrate",
    "run:permission": "bun scripts/fetchPermissionFromDb.ts",
    "email:dev": "bun email dev",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "typesVersions": {
    "*": {
      "types/*": [
        "./types/*"
      ],
      "modules": [
        "./modules/index.ts"
      ],
      "modules/*": [
        "./modules/*"
      ],
      "lib/*": [
        "./lib/*"
      ],
      "components/*": [
        "./components/*"
      ],
      "hooks/*": [
        "./hooks/*"
      ],
      "server/*": [
        "./server/*"
      ],
      "config/*": [
        "./config/*"
      ],
      "i18n/*": [
        "./i18n/*"
      ],
      "emails/*": [
        "./emails/*"
      ],
      "providers/*": [
        "./providers/*"
      ]
    }
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@ai-sdk/provider": "^1.1.3",
    "@ai-sdk/provider-utils": "^2.2.8",
    "@aws-sdk/client-s3": "^3.848.0",
    "@aws-sdk/s3-request-presigner": "^3.848.0",
    "@iconify/react": "^6.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^0.1.0",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^4.3.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.6",
    "drizzle-zod": "^0.8.3",
    "elysia": "^1.4.13",
    "framer-motion": "^12.16.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.546.0",
    "luxon": "^3.7.2",
    "nanoid": "^5.1.6",
    "next-auth": "5.0.0-beta.29",
    "next-intl": "^4.5.5",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.7",
    "react": "19.2.3",
    "react-day-picker": "^9.11.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.62.0",
    "react-resizable-panels": "^3.0.2",
    "resend": "^4.5.2",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.3.0",
    "use-file-picker": "^2.1.4",
    "zod": "^4.1.12"
  }
}
